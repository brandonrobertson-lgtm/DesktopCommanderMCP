{
  "name": "family-organizer",
  "version": "1.0.0",
  "description": "Comprehensive cross-platform family organization application",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm run install:mobile && npm run install:desktop && npm run install:web && npm run install:backend",
    "install:mobile": "cd mobile && npm install",
    "install:desktop": "cd desktop && npm install",
    "install:web": "cd web && npm install",
    "install:backend": "cd backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\"",
    "dev:mobile": "cd mobile && npm start",
    "dev:desktop": "cd desktop && npm run dev",
    "dev:web": "cd web && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:mobile && npm run build:desktop && npm run build:web && npm run build:backend",
    "build:mobile": "cd mobile && npm run build",
    "build:desktop": "cd desktop && npm run build",
    "build:web": "cd web && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:mobile && npm run test:desktop && npm run test:web && npm run test:backend",
    "test:mobile": "cd mobile && npm test",
    "test:desktop": "cd desktop && npm test",
    "test:web": "cd web && npm test",
    "test:backend": "cd backend && npm test",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
