{
  "name": "family-organizer-desktop",
  "version": "1.0.0",
  "description": "Family Organizer Desktop App",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "electron-builder --win",
    "package:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.familyorganizer.app",
    "productName": "Family Organizer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": ["portable"],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "FamilyOrganizer.exe"
    }
  }
}
